@using Microsoft.Extensions.Localization
@using IndaloaventurApp.SharedUI.Models.Auth
@using IndaloaventurApp.SharedUI.Resources

<section class="login-page">
    <div class="login-hero">
        <div class="login-hero__overlay"></div>
        <div class="login-hero__brand">
            <img class="login-hero__logo" src="_content/IndaloaventurApp.SharedUI/assets/images/logo.png" alt="@L["app_name"]" />
            <h1>@L["app_name"]</h1>
            <p>@L["login_subtitle"]</p>
        </div>
    </div>

    <div class="login-panel">
        <p class="login-panel__eyebrow">@L["auth_reset_eyebrow"]</p>
        <h2>@L["auth_reset_title"]</h2>
        <p class="login-panel__intro">@L["auth_reset_summary"]</p>

        @if (HasInvalidLink)
        {
            <div class="login-form__notice login-form__notice--warning" role="alert">
                @L["auth_reset_missing_link"]
            </div>
            <div class="login-panel__secondary-actions">
                <a href="/forgot-password">@L["auth_reset_restart_link"]</a>
            </div>
        }
        else
        {
            <EditForm Model="Form" OnValidSubmit="SubmitAsync" class="login-form">
                <DataAnnotationsValidator />

                <label for="resetEmail">@L["auth_reset_email_label"]</label>
                <input id="resetEmail" type="email" value="@Email" class="login-form__readonly" disabled />

                <label for="newPassword">@L["auth_reset_password_label"]</label>
                <InputText id="newPassword" type="password" @bind-Value="Form.NewPassword" placeholder="@L["auth_reset_password_placeholder"]" />
                <ValidationMessage For="() => Form.NewPassword" />

                <label for="confirmPassword">@L["auth_reset_confirm_label"]</label>
                <InputText id="confirmPassword" type="password" @bind-Value="Form.ConfirmPassword" placeholder="@L["auth_reset_confirm_placeholder"]" />
                <ValidationMessage For="() => Form.ConfirmPassword" />

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <p class="login-form__error" role="alert">@ErrorMessage</p>
                }

                <button type="submit" disabled="@IsSubmitting">@L["auth_reset_submit"]</button>
            </EditForm>

            @if (ShowRestartLink)
            {
                <div class="login-panel__secondary-actions">
                    <a href="/forgot-password">@L["auth_reset_restart_link"]</a>
                </div>
            }
            else
            {
                <div class="login-panel__secondary-actions">
                    <a href="/">@L["auth_recovery_back_to_login"]</a>
                </div>
            }
        }
    </div>
</section>
