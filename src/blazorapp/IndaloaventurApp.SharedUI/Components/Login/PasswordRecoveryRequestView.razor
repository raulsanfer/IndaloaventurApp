@using Microsoft.Extensions.Localization
@using IndaloaventurApp.SharedUI.Models.Auth
@using IndaloaventurApp.SharedUI.Resources

<section class="login-page">
    <div class="login-hero">
        <div class="login-hero__overlay"></div>
        <div class="login-hero__brand">
            <img class="login-hero__logo" src="_content/IndaloaventurApp.SharedUI/assets/images/logo.png" alt="@L["app_name"]" />
            <h1>@L["app_name"]</h1>
            <p>@L["login_subtitle"]</p>
        </div>
    </div>

    <div class="login-panel">
        <p class="login-panel__eyebrow">@L["auth_recovery_eyebrow"]</p>
        <h2>@L["auth_recovery_title"]</h2>
        <p class="login-panel__intro">@L["auth_recovery_summary"]</p>

        <EditForm Model="Form" OnValidSubmit="SubmitAsync" class="login-form">
            <DataAnnotationsValidator />

            <label for="recoveryEmail">@L["auth_recovery_email_label"]</label>
            <InputText id="recoveryEmail" type="email" @bind-Value="Form.Email" placeholder="@L["auth_recovery_email_placeholder"]" />
            <ValidationMessage For="() => Form.Email" />

            @if (!string.IsNullOrWhiteSpace(SuccessMessage))
            {
                <p class="login-form__notice" role="status">@SuccessMessage</p>
            }
            else if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <p class="login-form__error" role="alert">@ErrorMessage</p>
            }

            <button type="submit" disabled="@IsSubmitting">@L["auth_recovery_submit"]</button>
        </EditForm>

        <div class="login-panel__secondary-actions">
            <a href="/">@L["auth_recovery_back_to_login"]</a>
        </div>
    </div>
</section>
